      ],
      "id": "cd0cd204-04e4-4b89-aebd-932dc66890dd",
      "name": "Webhook响应"
    },
    {
      "parameters": {
        "jsCode": "// 路由节点：根据工作流类型选择不同的处理方式\nconst inputData = $input.all();\nconst results = [];\n\nfor (const item of inputData) {\n  const data = item.json;\n  \n  // 根据工作流类型设置路由信息\n  if (data.workflowType === 'code' || data.workflowType === 'quick') {\n    // 测试代码生成工作流\n    results.push({\n      json: {\n        ...data,\n        route: 'code_generation',\n        targetAgent: 'AI Agent'\n      }\n    });\n  } else if (data.workflowType === 'plan') {\n    // 测试方案生成工作流\n    results.push({\n      json: {\n        ...data,\n        route: 'test_plan',\n        targetAgent: 'AI Agent1'\n      }\n    });\n  } else {\n    // 默认使用代码生成工作流\n    results.push({\n      json: {\n        ...data,\n        route: 'code_generation',\n        targetAgent: 'AI Agent',\n        workflowType: 'code'\n      }\n    });\n  }\n}\n\nreturn results;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -100,
        60
      ],
      "id": "09cf3238-a563-45cf-8e25-8c4aaa003258",
      "name": "工作流路由"
    },
    {
      "parameters": {
        "jsCode": "// 错误处理节点\nconst inputData = $input.all();\nconst results = [];\n\nfor (const item of inputData) {\n  try {\n    const data = item.json;\n    \n    // 检查是否有错误\n    if (data.error || data.message?.includes('error')) {\n      const errorResponse = {\n        success: false,\n        timestamp: new Date().toISOString(),\n        workflowType: data.workflowType || 'unknown',\n        output: null,\n        message: '工作流执行失败',\n        error: data.error || data.message,\n        status: 'error'\n      };\n      \n      results.push({ json: errorResponse });\n    } else {\n      // 正常数据直接传递\n      results.push({ json: data });\n    }\n  } catch (error) {\n    // 捕获处理过程中的错误\n    const errorResponse = {\n      success: false,\n      timestamp: new Date().toISOString(),\n      workflowType: 'unknown',\n      output: null,\n      message: '数据处理失败',\n      error: error.message,\n      status: 'error'\n    };\n    \n    results.push({ json: errorResponse });\n  }\n}\n\nreturn results;"
      },
