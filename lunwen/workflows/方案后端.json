    {
      "parameters": {
        "jsCode": "// 格式化AI Agent的输出，使其适合网站显示\nconst inputData = $input.all();\nconst results = [];\n\nfor (const item of inputData) {\n  const data = item.json;\n  \n  // 检查是否有AI Agent的输出\n  if (data.output) {\n    const formattedOutput = {\n      success: true,\n      timestamp: new Date().toISOString(),\n      workflowType: data.workflowType || 'code',\n      output: data.output,\n      message: '测试代码生成完成',\n      status: 'completed'\n    };\n    \n    results.push({ json: formattedOutput });\n  } else if (data.error) {\n    const errorOutput = {\n      success: false,\n      timestamp: new Date().toISOString(),\n      workflowType: data.workflowType || 'code',\n      output: null,\n      message: '处理过程中出现错误',\n      error: data.error,\n      status: 'error'\n    };\n    \n    results.push({ json: errorOutput });\n  } else {\n    // 处理其他类型的数据\n    results.push({ json: data });\n  }\n}\n\nreturn results;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -900,
        520
      ],
      "id": "c75122f5-8c89-4c52-af73-62d9aebdcf59",
      "name": "格式化响应"
    },
